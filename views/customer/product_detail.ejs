<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
     <link rel="stylesheet" href="/stylesheets/customer/product_detail.css" />
    <title>Product Detail</title>
</head>
<body>
    <main class="product-detail-container">
        <div class="product-img-container">
            <img src="" alt="" id="product-img">
        </div>

        <div class="product-info-container">
            <h1 class="product-name">Product Name</h1>
            <p class="product-price">X.XX</p>
            <p class="product-description">
                Lorem ipsum dolor sit amet consectetur adipisicing elit. Vel, ab aspernatur iusto 
            </p>

            <p class="stock-status">Stock</p>
            <div class="quantity-selector">
                <button class="decrease-btn">-</button>
                <input 
                    type="number" 
                    id="quantity" 
                    value="1" 
                    min="1"
                >
                <button id="increase-qty">+</button>
            </div>

            <button class="add-to-basket">Add to Basket</button>
        </div>
    </main>
    <section class="related-products">
        <h2>Related Products</h2>
        <div class="related-grid">
            <div class="related-product-card">
                <img src="" alt="">
                <p class="related-product-name">Product Name</p>
                <p class="realted-product-price">X.XX</p>
            </div>
            <div class="related-product-card">
                <img src="" alt="">
                <p class="related-product-name">Product Name</p>
                <p class="realted-product-price">X.XX</p>
            </div>
            <div class="related-product-card">
                <img src="" alt="">
                <p class="related-product-name">Product Name</p>
                <p class="realted-product-price">X.XX</p>
            </div>
            <div class="related-product-card">
                <img src="" alt="">
                <p class="related-product-name">Product Name</p>
                <p class="realted-product-price">X.XX</p>
            </div>
        </div>
    </section>
</body>
</html>