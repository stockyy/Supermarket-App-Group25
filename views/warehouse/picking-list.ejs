    <div class="picking-controls">
        <input type="text" id="search-orders"/>
        <select id="status-filter">
            <option value="pending">Pending</option>
            <option value="ongoing">Ongoing</option>
            <option value="complete">Complete</option>
        </select>
    </div>

    <table>
        <thead>
            <tr>
                <th>Order ID</th>
                <th>Customer Name</th>
                <th>Delivery Slot</th>
                <th>Status</th>
                <th>Action</th>
            </tr>
        </thead>
        <tbody>
            <!-- This will be populate by the backend  -->
             <tr>
                <td>XXXID</td>
                <td>John Patel</td>
                <td>00:00 DD/MM/YY</td>
                <td><span class="picking-status-span">STATUS</span></td>
                <td>
                    <a href="/warehouse/picking/XXXXX">
                        <button class="pick-btn">Pick Order</button>
                    </a>
                </td>
            </tr>
        </tbody>
    </table>

    <p id="no-orders-message" style="display: none;">No orders currently assigned to warehouse.</p>
