        <ul class="main-nav-list">
            <li class="link-dashboard">
                <a class="nav-link main-nav-link dashboard-nav-link" href="#dashboard">Dashboard</a>
            </li>
            <li class="link-deliveries">
                <a class="nav-link main-nav-link pickingD-nav-link" href="#picking-detail">Picking Detail</a>
            </li>
            <li class="link-picking">
                <a class="nav-link main-nav-link pickingL-nav-link" href="">Picking List</a>
            </li>
            <li class="link-management">
                <a class="nav-link main-nav-link management-nav-link" href="">Stock Management</a>
            </li>
            <li class="link-profile">
                <a class="nav-link main-nav-link profile-nav-link" href="">Profile</a>
            </li>
        </ul>
